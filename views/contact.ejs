<%- include('partials/header') %>

<main class="max-w-7xl mx-auto px-6 py-16">
    <div class="grid lg:grid-cols-2 gap-16 items-start">
        
        <!-- Contact Info Section -->
        <div>
            <h1 class="text-4xl md:text-5xl font-bold text-[#2D1D30] mb-6">Let's Connect</h1>
            <p class="text-lg text-gray-600 mb-10">
                Reach out to us for support, partnerships, or general inquiries. Our team is here to help.
            </p>
            
            <div class="space-y-8">
                <!-- Location -->
                <div class="flex items-start gap-4">
                    <div class="bg-yellow-400 p-3 rounded-xl text-[#2D1D30]">
                        <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/></svg>
                    </div>
                    <div>
                        <h4 class="font-bold">Our Shelter</h4>
                        <p class="text-gray-600">Kiserian, Nairobi, Kenya</p>
                    </div>
                </div>

                <!-- Phone -->
                <div class="flex items-start gap-4">
                    <div class="bg-yellow-400 p-3 rounded-xl text-[#2D1D30]">
                        <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/></svg>
                    </div>
                    <div>
                        <h4 class="font-bold">Call Us</h4>
                        <p class="text-gray-600">+254 720 339 204</p>
                    </div>
                </div>

                <!-- Email -->
                <div class="flex items-start gap-4">
                    <div class="bg-yellow-400 p-3 rounded-xl text-[#2D1D30]">
                        <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/></svg>
                    </div>
                    <div>
                        <h4 class="font-bold">Email Us</h4>
                        <p class="text-gray-600">info@therebirthofaqueen.com</p>
                    </div>
                </div>
            </div>

            <!-- Embedded Map -->
            <div class="mt-12 rounded-3xl overflow-hidden shadow-sm border border-gray-100">
                <iframe src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d3988.5446591410946!2d36.669797777542726!3d-1.4477700358292869!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x182f010019253cf9%3A0xccf2d50576ec0c45!2sRebirth%20of%20a%20queen%20shelter!5e0!3m2!1sen!2ske!4v1784269438389!5m2!1sen!2ske" width="100%" height="300" style="border:0;" allowfullscreen="" loading="lazy"></iframe>
            </div>
        </div>

        <!-- Contact Form -->
        <div class="bg-white p-8 rounded-3xl shadow-sm border border-gray-100">
            <form action="/inquiry/contact" method="POST" class="space-y-4">
                <input type="text" name="name" placeholder="Full Name" required class="w-full p-4 border rounded-xl outline-none focus:border-[#522D59]">
                <input type="email" name="email" placeholder="Email Address" required class="w-full p-4 border rounded-xl outline-none focus:border-[#522D59]">
                <textarea name="message" rows="5" placeholder="Your Message" required class="w-full p-4 border rounded-xl outline-none focus:border-[#522D59]"></textarea>
                <button type="submit" class="w-full bg-[#522D59] text-white py-4 rounded-xl font-bold hover:bg-[#3D2142] transition">Send Message</button>
            </form>
        </div>
    </div>
</main>

<%- include('partials/footer') %>

<script>
    document.addEventListener('DOMContentLoaded', () => {
        const form = document.querySelector('form');
        const submitBtn = form.querySelector('button[type="submit"]');

        // 1. Handle Form Submission (Loading State)
        form.addEventListener('submit', () => {
            submitBtn.disabled = true;
            submitBtn.innerHTML = `
                <svg class="animate-spin h-5 w-5 mr-2 inline" viewBox="0 0 24 24">
                    <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle>
                    <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4z"></path>
                </svg>
                Sending...
            `;
            submitBtn.classList.add('opacity-70', 'cursor-not-allowed');
        });

        // 2. Handle Success Notification
        const urlParams = new URLSearchParams(window.location.search);
        if (urlParams.get('status') === 'success') {
            Swal.fire({
                title: 'Message Sent!',
                text: 'Thank you for reaching out. We have received your message and will get back to you shortly.',
                icon: 'success',
                confirmButtonColor: '#522D59',
                confirmButtonText: 'Okay'
            }).then(() => {
                window.history.replaceState({}, document.title, window.location.pathname);
            });
        }
    });
</script>