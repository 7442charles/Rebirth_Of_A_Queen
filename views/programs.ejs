<%- include('partials/header') %>

<main class="min-h-screen bg-[#FDFBF7]">
    <!-- Programs Hero Section -->
    <section class="relative h-[60vh] flex items-center justify-center">
        <!-- Background Image -->
        <div class="absolute inset-0 z-0">
            <img src="/images/Peer_mentorship_and_leadership-session.png" alt="Our programs" class="w-full h-full object-cover">
            <!-- Dark Overlay -->
            <div class="absolute inset-0 bg-[#2D1D30]/80"></div>
        </div>

        <!-- Content -->
        <div class="container mx-auto px-6 relative z-10 text-left">
            <div class="max-w-3xl">
                <span class="text-yellow-400 font-bold tracking-widest uppercase text-sm border-l-4 border-white pl-4">Our Work</span>
                <h1 class="text-4xl md:text-6xl font-extrabold text-white mt-6 leading-tight">
                    Five programs. One continuum, from prevention to transformation.
                </h1>
                <p class="text-white/90 mt-6 text-lg md:text-xl">
                    Each program answers a different need in the survivor journey, building a future where safety and dignity are accessible to everyone.
                </p>
            </div>
        </div>
    </section>

    <section class="py-20 px-6 bg-[#FDFBF7]">
        <div class="container mx-auto flex flex-col lg:flex-row items-center gap-12">
            
            <div class="w-full lg:w-1/2">
                <div class="relative">
                    <img src="/images/Community_awareness_and_engagement_session.png" alt="Prevention, Advocacy & Community Engagement" class="rounded-3xl shadow-2xl w-full h-auto object-cover">
                    <div class="absolute top-6 left-6 bg-yellow-400 text-black font-bold px-4 py-2 rounded-lg shadow-md">
                        01 · Prevent
                    </div>
                </div>
            </div>

            <div class="w-full lg:w-1/2 space-y-6">
                <h2 class="text-3xl md:text-4xl font-extrabold text-[#2D1D30] leading-tight">
                    Prevention, Advocacy & Community Engagement
                </h2>
                <p class="text-gray-600 leading-relaxed text-lg">
                    Creating informed communities that actively prevent sexual violence and human trafficking through awareness campaigns, community dialogue, and advocacy for stronger protective systems.
                </p>
            </div>
        </div>
    </section>

    <!-- 02 · Protect Stage Section -->
    <section class="py-16 px-6">
        <div class="container mx-auto">
            <div class="bg-[#2E1633] text-white p-12 md:p-16 rounded-3xl text-center shadow-xl">
                <!-- Label -->
                <div class="flex justify-center items-center gap-2 mb-6">
                    <span class="w-8 h-px bg-yellow-400"></span>
                    <span class="text-yellow-400 font-bold tracking-widest uppercase text-sm">02 · Protect</span>
                    <span class="w-8 h-px bg-yellow-400"></span>
                </div>

                <!-- Headline -->
                <h2 class="text-3xl md:text-4xl font-bold mb-6">
                    Rescue, Protection & Survivor Support
                </h2>

                <!-- Description -->
                <p class="text-white/80 text-lg md:text-xl max-w-2xl mx-auto leading-relaxed">
                    Providing holistic, survivor-centered care including shelter, counselling, safeguarding, and referrals — built around dignity and choice at every step.
                </p>
            </div>
        </div>
    </section>

    <!-- 03 · Heal Detail Section -->
    <section class="py-20 px-6 bg-[#FDFBF7]">
        <div class="container mx-auto flex flex-col lg:flex-row-reverse items-center gap-12">
            
            <!-- Right: Image (Swapped to right side for layout variety) -->
            <div class="w-full lg:w-1/2">
                <div class="relative">
                    <img src="/images/Peer_mentorship_and_leadership-session.png" alt="Healing, Leadership & Reintegration" class="rounded-3xl shadow-2xl w-full h-auto object-cover">
                    <!-- Badge -->
                    <div class="absolute top-6 left-6 bg-yellow-400 text-black font-bold px-4 py-2 rounded-lg shadow-md">
                        03 · Heal
                    </div>
                </div>
            </div>

            <!-- Left: Text Content -->
            <div class="w-full lg:w-1/2 space-y-6">
                <h2 class="text-3xl md:text-4xl font-extrabold text-[#2D1D30] leading-tight">
                    Healing, Leadership & Reintegration
                </h2>
                <p class="text-gray-600 leading-relaxed text-lg">
                    Helping survivors rebuild confidence, develop leadership, and reintegrate into society through mentorship and long-term community support.
                </p>
            </div>
        </div>
    </section>

    <!-- 04 · Empower Detail Section -->
    <section class="py-20 px-6 bg-[#FDFBF7]">
        <div class="container mx-auto flex flex-col lg:flex-row items-center gap-12">
            
            <!-- Left: Image -->
            <div class="w-full lg:w-1/2">
                <div class="relative">
                    <img src="/images/Tailoring_training.png" alt="Skills Development & Economic Empowerment" class="rounded-3xl shadow-2xl w-full h-auto object-cover">
                    <!-- Badge -->
                    <div class="absolute top-6 left-6 bg-yellow-400 text-black font-bold px-4 py-2 rounded-lg shadow-md">
                        04 · Empower
                    </div>
                </div>
            </div>

            <!-- Right: Text Content -->
            <div class="w-full lg:w-1/2 space-y-6">
                <h2 class="text-3xl md:text-4xl font-extrabold text-[#2D1D30] leading-tight">
                    Skills Development & Economic Empowerment
                </h2>
                <p class="text-gray-600 leading-relaxed text-lg">
                    Equipping women and youth with practical skills, entrepreneurship training, and sustainable livelihood opportunities — the foundation of lasting independence.
                </p>
            </div>
        </div>
    </section>

<!-- 05 · Transform Detail Section -->
<section class="py-20 px-6 bg-[#FDFBF7]">
    <div class="container mx-auto flex flex-col lg:flex-row-reverse items-center gap-12">
        
        <!-- Right: Image (Swapped to right side) -->
        <div class="w-full lg:w-1/2">
            <div class="relative">
                <img src="/images/Creative_and_digital_skills_training.png" alt="Research, Innovation & Systems Strengthening" class="rounded-3xl shadow-2xl w-full h-auto object-cover">
                <!-- Badge -->
                <div class="absolute top-6 left-6 bg-yellow-400 text-black font-bold px-4 py-2 rounded-lg shadow-md">
                    05 · Transform
                </div>
            </div>
        </div>

        <!-- Left: Text Content -->
        <div class="w-full lg:w-1/2 space-y-6">
            <h2 class="text-3xl md:text-4xl font-extrabold text-[#2D1D30] leading-tight">
                Research, Innovation & Systems Strengthening
            </h2>
            <p class="text-gray-600 leading-relaxed text-lg">
                Building evidence, partnerships, and innovative solutions that strengthen how communities and institutions respond to violence and trafficking.
            </p>
        </div>
    </div>
</section>

<!-- Social Enterprises CTA Section -->
<section class="py-24 px-6 bg-[#2E1633] text-center">
    <div class="container mx-auto max-w-3xl">
        <!-- Label -->
        <div class="flex justify-center items-center gap-2 mb-8">
            <span class="w-8 h-px bg-yellow-400"></span>
            <span class="text-yellow-400 font-bold tracking-widest uppercase text-sm">From program to practice</span>
            <span class="w-8 h-px bg-yellow-400"></span>
        </div>

        <!-- Headline -->
        <h2 class="text-4xl md:text-5xl font-extrabold text-white leading-tight mb-8">
            Economic empowerment turns training into a livelihood.
        </h2>

        <!-- Description -->
        <p class="text-white/80 text-lg md:text-xl mb-12">
            Our social enterprises, Amka Creations and Fitness Buddies, give survivors a place to put new skills to work.
        </p>

        <!-- Button -->
        <a href="/social-enterprises" class="inline-block bg-yellow-400 text-[#2E1633] font-bold py-4 px-8 rounded-full text-lg hover:bg-yellow-300 transition duration-300">
            Meet our social enterprises
        </a>
    </div>
</section>


<!--  CTA Section -->
<section class="py-20 px-6 bg-[#FDFBF7] text-center">
    <div class="container mx-auto">
        <!-- Label -->
        <div class="flex justify-center items-center gap-2 mb-6">
            <span class="w-8 h-px bg-yellow-400"></span>
            <span class="text-yellow-400 font-bold tracking-widest uppercase text-sm">Ready to help?</span>
            <span class="w-8 h-px bg-yellow-400"></span>
        </div>

        <!-- Headline -->
        <h2 class="text-4xl md:text-5xl font-extrabold text-[#2D1D30] leading-tight mb-10 max-w-2xl mx-auto">
            Your support keeps every stage of this work moving.
        </h2>

        <!-- Action Buttons -->
        <div class="flex flex-col sm:flex-row justify-center gap-4">
            <a href="/support" class="bg-[#522D59] text-white font-bold py-4 px-8 rounded-full hover:bg-[#3D2142] transition">
                Support Our Mission
            </a>
            <a href="/partner" class="border-2 border-[#522D59] text-[#522D59] font-bold py-4 px-8 rounded-full hover:bg-[#522D59] hover:text-white transition">
                Partner With Us
            </a>
        </div>
    </div>
</section>

</main>

<%- include('partials/footer') %>