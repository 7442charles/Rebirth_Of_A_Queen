<%- include('../partials/header') %>
<main class="py-20 bg-[#FDFBF7] px-6">
    <div class="max-w-md mx-auto bg-white p-8 rounded-3xl shadow-lg">
        <h2 class="text-3xl font-bold text-[#2D1D30] mb-6 text-center">Reset Password</h2>
        <form action="/forgot-password" method="POST" class="space-y-4">
            <input type="email" name="email" placeholder="Enter your registered email" required class="w-full p-4 border rounded-xl">
            <button type="submit" class="w-full bg-[#522D59] text-white p-4 rounded-xl font-bold">Send Reset Link</button>
        </form>
    </div>
</main>
<%- include('../partials/footer') %>