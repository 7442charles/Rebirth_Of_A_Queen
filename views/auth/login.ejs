<%- include('../partials/header') %>
<script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>

<main class="py-20 bg-[#FDFBF7] px-6">
    <div class="max-w-md mx-auto bg-white p-8 rounded-3xl shadow-lg">
        <h2 class="text-3xl font-bold text-[#2D1D30] mb-8 text-center">Welcome Back</h2>
        
        <form id="loginForm" class="space-y-6">
            <div class="relative">
                <input type="email" id="email" name="email" required placeholder=" " class="peer w-full p-4 border-2 rounded-xl focus:border-[#522D59] outline-none transition-all pt-6">
                <label for="email" class="absolute left-4 top-4 text-gray-400 transition-all peer-placeholder-shown:top-4 peer-placeholder-shown:text-base peer-focus:top-1 peer-focus:text-xs peer-focus:text-[#522D59]">Email Address</label>
            </div>

            <div class="relative">
                <input type="password" id="password" name="password" required placeholder=" " class="peer w-full p-4 border-2 rounded-xl focus:border-[#522D59] outline-none transition-all pt-6">
                <label for="password" class="absolute left-4 top-4 text-gray-400 transition-all peer-placeholder-shown:top-4 peer-placeholder-shown:text-base peer-focus:top-1 peer-focus:text-xs peer-focus:text-[#522D59]">Password</label>
                <button type="button" onclick="togglePassword('password')" class="absolute right-4 top-4 text-gray-500">
                    <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"/><path stroke-width="2" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z"/></svg>
                </button>
            </div>

            <button type="submit" class="w-full bg-[#522D59] text-white p-4 rounded-xl font-bold hover:bg-[#3D2142] transition-colors">Login</button>
        </form>

        <p class="mt-6 text-center text-sm">
            <a href="/forgot-password" class="text-[#522D59] underline font-medium">Forgot Password?</a>
        </p>
    </div>
</main>

<script>
    function togglePassword(id) {
        const input = document.getElementById(id);
        input.type = input.type === 'password' ? 'text' : 'password';
    }

    const loginForm = document.getElementById('loginForm');

    loginForm.addEventListener('submit', async (e) => {
        e.preventDefault();
        
        const formData = new FormData(loginForm);
        const data = Object.fromEntries(formData.entries());

        // Show loading spinner
        Swal.fire({
            title: 'Authenticating...',
            allowOutsideClick: false,
            didOpen: () => { Swal.showLoading(); }
        });

        try {
            const response = await fetch('/login', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify(data)
            });

            const result = await response.json();

            if (response.ok) {
                // SUCCESS: Show alert, set a 1.5s timer, and redirect automatically
                Swal.fire({
                    icon: 'success',
                    title: 'Login successful!',
                    text: 'Redirecting you...',
                    timer: 1500, // Closes after 1.5 seconds
                    timerProgressBar: true,
                    showConfirmButton: false, // Removes the "OK" button
                    didClose: () => {
                        window.location.href = result.redirectUrl;
                    }
                });
            } else {
                // ERROR: Keep the "OK" button so they can read the error
                Swal.fire({
                    icon: 'error',
                    title: 'Login Failed',
                    text: result.message,
                    confirmButtonColor: '#522D59'
                });
            }
        } catch (err) {
            Swal.fire({
                icon: 'error',
                title: 'Error',
                text: 'Something went wrong, please try again.',
                confirmButtonColor: '#522D59'
            });
        }
    });
</script>
<%- include('../partials/footer') %>