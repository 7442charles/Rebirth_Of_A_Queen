<%- include('../partials/adminHeader') %>


<div class="flex min-h-screen bg-gray-50">


  <main class="flex-1 p-4 md:p-8">
    <div class="max-w-6xl mx-auto">
      <div class="mb-6 md:mb-8 flex flex-col md:flex-row md:items-end md:justify-between gap-3">
        <div>
          <h1 class="text-2xl md:text-3xl font-bold text-[#2D1D30]">Blog Posts</h1>
          <p class="text-sm text-gray-600 mt-2">Manage existing posts and create new blog content.</p>
        </div>

        <div class="flex items-center gap-3">
          <span class="text-sm text-gray-500">
            <%= (posts && posts.length) ? posts.length : 0 %> posts
          </span>

          <button
            id="openCreateBlog"
            type="button"
            class="bg-[#522D59] text-white px-5 py-3 rounded-xl font-bold hover:bg-[#3D2142] transition"
          >
            Create New Blog
          </button>
        </div>
      </div>

      <div class="bg-white p-5 md:p-6 rounded-3xl shadow-sm border border-gray-100">
        <div class="flex items-center justify-between mb-4">
          <h2 class="text-lg font-bold text-[#2D1D30]">Existing Posts</h2>
        </div>

        <div class="lg:max-h-[74vh] lg:overflow-auto pr-1">
          <div class="space-y-3" id="postsList">
            <% if (posts && posts.length > 0) { %>
              <% posts.forEach(function(p) { %>
                <div class="rounded-2xl border border-gray-100 bg-gray-50 hover:bg-white transition">
                  <div class="p-4 flex items-start gap-4">
                    <button
                      type="button"
                      class="flex-1 text-left"
                      style="outline:none"
                      onclick="window.BlogLoader.load(<%= p.id %>)"
                    >
                      <div class="font-bold text-[#2D1D30] leading-tight">
                        <%= p.title %>
                      </div>

                      <div class="text-sm text-gray-500 mt-1 line-clamp-2">
                        <%= (p.content ? p.content : '').slice(0, 160) %>
                      </div>

                      <div class="text-xs text-gray-400 mt-2">
                        <%= p.created_at || '' %>
                      </div>
                    </button>

                    <div class="flex flex-col gap-2 shrink-0">
                      <button
                        type="button"
                        class="px-3 py-2 rounded-xl text-sm border border-gray-200 hover:border-[#522D59] transition"
                        onclick="window.BlogLoader.load(<%= p.id %>)"
                      >
                        Edit
                      </button>

                      <button
                        type="button"
                        class="px-3 py-2 rounded-xl text-sm bg-red-50 text-red-700 hover:bg-red-100 transition"
                        onclick="window.BlogLoader.remove(<%= p.id %>)"
                      >
                        Delete
                      </button>
                    </div>
                  </div>
                </div>
              <% }) %>
            <% } else { %>
              <div class="py-10 text-center text-gray-400">No blog posts found.</div>
            <% } %>
          </div>
        </div>
      </div>
    </div>
  </main>
</div>

<!-- Modal -->
<div id="blogModalBackdrop" class="fixed inset-0 bg-black/40 z-[59] hidden"></div>

<div
  id="blogModal"
  class="fixed inset-0 z-[60] hidden"
  aria-hidden="true"
>
  <div class="flex items-center justify-center min-h-screen px-4">
    <div class="bg-white rounded-3xl shadow-xl w-full max-w-4xl border border-gray-100">
      <div class="p-5 md:p-6 flex items-start justify-between gap-4 border-b border-gray-100">
        <div>
          <h2 class="text-xl md:text-2xl font-bold text-[#2D1D30]">Create / Edit Blog</h2>
          <p id="blogStatus" class="text-sm text-gray-600 mt-1"></p>
        </div>

        <button
          id="closeBlogModal"
          type="button"
          class="px-3 py-2 rounded-xl border border-gray-200 hover:border-gray-300 transition"
        >
          ✕
        </button>
      </div>

      <div class="p-5 md:p-6">
        <form id="blogForm" action="/admin/save" method="POST" class="space-y-4">
          <input type="hidden" id="postId" name="id" value="" />

          <div>
            <label class="block text-sm font-bold text-gray-700 mb-2">Title</label>
            <input
              type="text"
              id="postTitle"
              name="title"
              class="w-full p-3 border rounded-xl outline-none focus:border-[#522D59]"
              placeholder="e.g. Community Awareness Session"
              required
            />
          </div>

          <div>
            <label class="block text-sm font-bold text-gray-700 mb-2">Content</label>

            <textarea
              id="summernoteBlog"
              name="content"
              class="w-full"
              placeholder="Write blog content..."
            ></textarea>
          </div>

          <button
            type="submit"
            class="w-full bg-[#522D59] text-white py-3 rounded-xl font-bold hover:bg-[#3D2142] transition"
          >
            Save Post
          </button>
        </form>
      </div>
    </div>
  </div>
</div>

<script>
  function openBlogModal() {
    document.getElementById('blogModalBackdrop').classList.remove('hidden');
    document.getElementById('blogModal').classList.remove('hidden');
    document.getElementById('blogModal').classList.add('block');
    document.getElementById('blogModalBackdrop').classList.add('block');

    // give summernote a moment to size correctly (it recalculates layout after visible)
    setTimeout(() => {
      try {
        $('#summernoteBlog').summernote('focus');
      } catch (e) {}
    }, 150);
  }

  function closeBlogModal() {
    document.getElementById('blogModal').classList.add('hidden');
    document.getElementById('blogModalBackdrop').classList.add('hidden');
  }

  const openCreateBtn = document.getElementById('openCreateBlog');
  if (openCreateBtn) {
    openCreateBtn.addEventListener('click', () => {
      document.getElementById('postId').value = '';
      document.getElementById('postTitle').value = '';
      document.getElementById('blogStatus').textContent = 'Creating a new post...';
      $('#summernoteBlog').summernote('code', '');
      openBlogModal();
    });
  }

  const closeBlogModalBtn = document.getElementById('closeBlogModal');
  if (closeBlogModalBtn) {
    closeBlogModalBtn.addEventListener('click', closeBlogModal);
  }

  const backdrop = document.getElementById('blogModalBackdrop');
  if (backdrop) backdrop.addEventListener('click', closeBlogModal);

  window.BlogLoader = {
    load: async function(id) {
      document.getElementById('postId').value = id;
      document.getElementById('blogStatus').textContent = 'Loading post #' + id + '...';

      const resp = await fetch('/admin/blog/' + id);
      if (!resp.ok) {
        Swal.fire('Error', 'Failed to load post.', 'error');
        return;
      }

      const post = await resp.json();
      document.getElementById('postTitle').value = post.title || '';
      $('#summernoteBlog').summernote('code', post.content || '');
      document.getElementById('blogStatus').textContent = 'Editing post #' + id;

      openBlogModal();
    },

    remove: async function(id) {
      const ok = await Swal.fire({
        title: 'Delete this post?',
        text: 'This action cannot be undone.',
        icon: 'warning',
        showCancelButton: true,
        confirmButtonColor: '#522D59',
        cancelButtonColor: '#d1d5db',
        confirmButtonText: 'Yes, delete'
      });

      if (!ok.isConfirmed) return;

      const resp = await fetch('/admin/blog/' + id + '/delete', { method: 'POST' });
      if (!resp.ok) {
        Swal.fire('Error', 'Failed to delete post.', 'error');
        return;
      }

      Swal.fire('Deleted', 'Post removed successfully.', 'success').then(() => location.reload());
    }
  };

  $(document).ready(function() {
    $('#summernoteBlog').summernote({
      placeholder: 'Write your blog content...',
      tabsize: 2,
      height: 520,
      toolbar: [
        ['style', ['style']],
        ['font', ['bold', 'underline', 'clear']],
        ['color', ['color']],
        ['para', ['ul', 'ol', 'paragraph']],
        ['insert', ['link', 'picture', 'video']]
      ],
      callbacks: {
        onImageUpload: function(files) {
          if (!files || !files[0]) return;

          const formData = new FormData();
          formData.append('image', files[0]);

          return fetch('/admin/blog/upload-image', {
            method: 'POST',
            body: formData
          })
            .then(async (res) => {
              if (!res.ok) {
                throw new Error('Image upload failed');
              }
              return res.json();
            })
            .then((data) => {
              const url = data && data.url ? data.url : null;
              if (!url) throw new Error('No url returned');
              $('#summernoteBlog').summernote('insertImage', url);
            })
            .catch((err) => {
              Swal.fire('Error', err.message || 'Image upload failed', 'error');
            });
        }
      }
    });

    // Ensure scrolling stays inside the editor area (not the whole page)
    const editor = $('#summernoteBlog').next('.note-editor');
    const editable = editor.find('.note-editable');
    editable.css({
      overflowY: 'auto',
      maxHeight: '420px'
    });

  });
</script>

