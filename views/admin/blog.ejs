<%- include('../partials/adminHeader') %>

<main class="flex-1 p-6 md:p-10 bg-gray-50 min-h-screen">
  <div id="blogs-manager-content" class="space-y-10 max-w-5xl mx-auto">
      
    <!-- Form Section (Create / Edit) -->
    <section class="bg-white rounded-3xl p-8 shadow-sm border border-slate-100">
        <div class="flex justify-between items-center mb-6">
            <div class="flex items-center gap-3">
                <i class="fa-solid fa-pen-to-square text-[#522D59]"></i>
                <h2 class="text-xl font-black uppercase tracking-tight text-[#2D1D30]" id="form-title">Create New Post</h2>
            </div>
            <button type="button" onclick="resetBlogForm()" id="cancel-edit-btn" class="hidden text-sm text-red-500 font-bold hover:underline">Cancel Edit</button>
        </div>
 
        <form id="blog-form" method="POST" action="/admin/blog" class="space-y-4" enctype="multipart/form-data">
          <input type="text" name="title" id="blog-title-input" placeholder="Blog Title" class="w-full border-slate-200 border rounded-xl px-4 py-3 focus:ring-2 focus:ring-[#522D59] outline-none transition-all font-bold" required>
          
          <div class="flex gap-2 items-center">
            <input type="file" name="coverImage" id="cover-image-input" accept="image/*" class="w-full border-slate-200 border rounded-xl px-4 py-3 focus:ring-2 focus:ring-[#522D59] outline-none transition-all bg-white" required>
            <div id="current-cover-msg" class="hidden px-4 py-3 bg-slate-100 rounded-xl text-xs flex items-center text-slate-500 whitespace-nowrap">Current image set</div>
          </div>

          <textarea name="excerpt" id="blog-excerpt-input" placeholder="Short Excerpt" class="w-full border-slate-200 border rounded-xl px-4 py-3 focus:ring-2 focus:ring-[#522D59] outline-none transition-all h-24" required></textarea>
          
          <div class="rounded-xl overflow-hidden border border-slate-200">
              <textarea id="editor" name="content"></textarea>
          </div>

          <button type="submit" id="form-submit-btn" class="bg-[#522D59] text-white font-black px-8 py-3 rounded-xl hover:bg-[#3D2142] transition-all shadow-lg">
            Publish Post
          </button>
        </form>
    </section>

    <!-- All Blogs Listing Section -->
    <section class="bg-white rounded-3xl p-8 shadow-sm border border-slate-100">
        <div class="flex items-center justify-between mb-6">
            <h2 class="text-xl font-black uppercase tracking-tight text-[#2D1D30]">All Blogs (<%= blogs.length %>)</h2>
        </div>
        
        <div class="space-y-3">
            <% if (blogs && blogs.length > 0) { %>
              <% blogs.forEach(b => { %>
                <div class="flex justify-between items-center bg-slate-50 p-4 rounded-2xl hover:bg-slate-100 transition-colors group">
                    <div class="flex items-center gap-4">
                      <% if(b.cover_image) { %>
                        <img src="<%= b.cover_image %>" class="w-12 h-12 rounded-lg object-cover">
                      <% } else { %>
                        <div class="w-12 h-12 rounded-lg bg-slate-200 flex items-center justify-center"><i class="fa-solid fa-image text-slate-400"></i></div>
                      <% } %>
                      <div>
                        <span class="font-bold text-slate-700 block"><%= b.title %></span>
                        <span class="text-xs text-slate-400"><%= b.created_at ? new Date(b.created_at).toLocaleDateString() : '' %></span>
                      </div>
                    </div>
                    
                    <div class="flex items-center gap-2">
                      <button type="button" onclick="editBlog('<%= b.id %>')" class="w-9 h-9 rounded-xl bg-white border border-slate-200 flex items-center justify-center text-slate-600 hover:bg-[#522D59] hover:text-white transition-all shadow-sm">
                          <i class="fa-solid fa-pen text-sm"></i>
                      </button>

                      <form action="/admin/blog/<%= b.id %>/delete" method="POST" onsubmit="return confirm('Are you sure you want to delete this blog?');" class="inline">
                        <button type="submit" class="w-9 h-9 rounded-xl bg-white border border-slate-200 flex items-center justify-center text-red-500 hover:bg-red-500 hover:text-white transition-all shadow-sm">
                            <i class="fa-solid fa-trash text-sm"></i>
                        </button>
                      </form>
                    </div>
                </div>
              <% }) %>
            <% } else { %>
              <div class="py-8 text-center text-slate-400">No blog posts found.</div>
            <% } %>
        </div>
    </section>
  </div>
</main>

<!-- FontAwesome for icons -->
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">

<script>
  $(document).ready(function() {
    $('#editor').summernote({
      placeholder: 'Write your complete blog content here...',
      tabsize: 2,
      height: 350,
      toolbar: [
        ['style', ['style']],
        ['font', ['bold', 'underline', 'clear']],
        ['color', ['color']],
        ['para', ['ul', 'ol', 'paragraph']],
        ['insert', ['link', 'picture', 'video']]
      ]
    });
  });

  // Switch form action and fields dynamically to support editing
  async function editBlog(id) {
    try {
      const response = await fetch('/admin/blog/json/' + id);
      if (!response.ok) throw new Error('Failed to fetch post details');
      const post = await response.json();

      // Update form state
      const form = document.getElementById('blog-form');
      form.action = '/admin/blogs/edit/' + id;
      
      document.getElementById('form-title').textContent = 'Edit Blog Post #' + id;
      document.getElementById('form-submit-btn').textContent = 'Update Changes';
      document.getElementById('cancel-edit-btn').classList.remove('hidden');

      // Populate values
      document.getElementById('blog-title-input').value = post.title || '';
      document.getElementById('blog-excerpt-input').value = post.excerpt || '';
      $('#editor').summernote('code', post.content || '');

      // Cover image is optional on edit
      const coverInput = document.getElementById('cover-image-input');
      coverInput.removeAttribute('required');
      document.getElementById('current-cover-msg').classList.remove('hidden');

      window.scrollTo({ top: 0, behavior: 'smooth' });
    } catch (err) {
      alert('Error loading blog content for editing.');
    }
  }

  function resetBlogForm() {
    const form = document.getElementById('blog-form');
    form.action = '/admin/blog';
    
    document.getElementById('form-title').textContent = 'Create New Post';
    document.getElementById('form-submit-btn').textContent = 'Publish Post';
    document.getElementById('cancel-edit-btn').classList.add('hidden');

    form.reset();
    $('#editor').summernote('code', '');

    const coverInput = document.getElementById('cover-image-input');
    coverInput.setAttribute('required', 'true');
    document.getElementById('current-cover-msg').classList.add('hidden');
  }
</script>