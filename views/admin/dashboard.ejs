<%- include('../partials/adminHeader') %>


<main class="flex-1 p-4 md:p-8">
    <div class="flex justify-between items-center mb-8">
        <h1 class="text-3xl font-bold text-[#2D1D30]">Dashboard</h1>
        <a href="/admin/blog" class="bg-[#522D59] text-white px-6 py-2 rounded-xl hover:bg-[#3D2142] transition">
            + Add New Blog
        </a>
    </div>
    
    <!-- Analytics Grid -->
    <div class="grid grid-cols-1 md:grid-cols-3 gap-6 mb-8">
        <div class="bg-white p-6 rounded-3xl shadow-sm border border-gray-100">
            <p class="text-gray-500 text-sm">Total Published Blogs</p>
            <h3 class="text-3xl font-bold text-[#2D1D30]"><%= totalBlogs %></h3>
        </div>
        <!-- Pending Inquiries Card -->
        <div class="bg-white p-6 rounded-3xl shadow-sm border border-gray-100 border-l-4 border-l-red-500">
            <p class="text-gray-500 text-sm">Pending Inquiries</p>
            <h3 class="text-3xl font-bold text-red-600"><%= pendingInquiries %></h3>
            <a href="/admin/inquiries" class="text-xs text-red-500 underline mt-2 block">View Pending</a>
        </div>
        
        <div class="bg-white p-6 rounded-3xl shadow-sm border border-gray-100">
            <p class="text-gray-500 text-sm">Gallery Items</p>
            <h3 class="text-3xl font-bold text-[#2D1D30]"><%= totalGalleryItems %></h3>
        </div>
    </div>
    
    <!-- Existing Create Content form... -->
</main>

