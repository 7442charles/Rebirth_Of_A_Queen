<%- include('./partials/header', { title: title || 'All Blogs | Rebirth of a Queen' }) %>

<main class="max-w-6xl mx-auto px-4 py-10">
  <div class="mb-8">
    <a href="/blog" class="text-purple-700 font-semibold hover:underline">&larr; Back to Home Blog</a>
    <h1 class="text-3xl md:text-4xl font-bold text-[#2D1D30] mt-4">All Blog Posts</h1>
    <p class="text-gray-600 mt-2">Explore all stories, updates, and announcements from Rebirth of a Queen.</p>
  </div>

  <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
    <% if (posts && posts.length) { %>
      <% posts.forEach(post => { %>
        <a href="/blog/<%= post.slug %>" class="group bg-white border border-gray-100 rounded-3xl p-6 hover:shadow-sm transition">
          <div class="flex items-center justify-between gap-4">
            <h2 class="text-xl font-bold text-[#2D1D30] group-hover:text-purple-800 transition">
              <%= post.title %>
            </h2>
          </div>

          <p class="text-gray-600 mt-3 line-clamp-3">
            <%- (post.content || '').replace(/<[^>]*>/g, '').slice(0, 180) %><% if ((post.content || '').replace(/<[^>]*>/g, '').length > 180) { %>...<% } %>
          </p>

          <div class="text-sm text-gray-500 mt-4">
            <%= post.created_at ? new Date(post.created_at).toLocaleDateString() : '' %>
          </div>
        </a>
      <% }) %>
    <% } else { %>
      <div class="col-span-full text-center text-gray-400 py-12">
        No blog posts found.
      </div>
    <% } %>
  </div>
</main>

<%- include('./partials/footer') %>