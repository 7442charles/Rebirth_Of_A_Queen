<!-- views/partials/admin-sidebar.ejs -->
<!-- Mobile toggle button + overlay -->
<button
  id="admin-sidebar-toggle"
  type="button"
  class="fixed top-4 left-4 z-50 md:hidden bg-[#522D59] text-white p-3 rounded-xl shadow-sm"
>
  <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16m-7 6h7" />
  </svg>
</button>

<div id="admin-sidebar-overlay" class="fixed inset-0 bg-black bg-opacity-50 z-40 hidden"></div>

<aside
  id="admin-sidebar"
  class="fixed md:static md:w-64 w-64 z-50 inset-y-0 left-0 transform -translate-x-full md:translate-x-0
         bg-[#2D1D30] text-white p-6 transition-transform duration-300 ease-in-out"
>
  <div class="flex items-center justify-between mb-10">
    <h2 class="text-2xl font-bold">Admin Panel</h2>
    <button id="admin-sidebar-close" type="button" class="md:hidden text-white">
      <svg class="w-8 h-8" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
      </svg>
    </button>
  </div>

  <nav class="space-y-2">
    <a href="/admin/dashboard" class="block py-3 px-4 rounded-xl transition <%= activePage === 'dashboard' ? 'bg-[#522D59]' : 'hover:bg-[#522D59]' %>">Dashboard</a>
    <a href="/admin/inquiries" class="block py-3 px-4 rounded-xl transition <%= activePage === 'inquiries' ? 'bg-[#522D59]' : 'hover:bg-[#522D59]' %>">Inquiries</a>
    <a href="/admin/programs" class="block py-3 px-4 rounded-xl transition <%= activePage === 'programs' ? 'bg-[#522D59]' : 'hover:bg-[#522D59]' %>">Programs</a>
    <a href="/admin/blog" class="block py-3 px-4 rounded-xl transition <%= activePage === 'blog' ? 'bg-[#522D59]' : 'hover:bg-[#522D59]' %>">Blog Posts</a>
    <a href="/admin/gallery" class="block py-3 px-4 rounded-xl transition <%= activePage === 'gallery' ? 'bg-[#522D59]' : 'hover:bg-[#522D59]' %>">Gallery</a>
    <a href="/admin/settings" class="block py-3 px-4 rounded-xl transition <%= activePage === 'settings' ? 'bg-[#522D59]' : 'hover:bg-[#522D59]' %>">Settings</a>
  </nav>
</aside>

<script>
  (function () {
    const toggle = document.getElementById('admin-sidebar-toggle');
    const closeBtn = document.getElementById('admin-sidebar-close');
    const sidebar = document.getElementById('admin-sidebar');
    const overlay = document.getElementById('admin-sidebar-overlay');

    if (!toggle || !closeBtn || !sidebar || !overlay) return;

    const open = () => {
      sidebar.classList.remove('-translate-x-full');
      overlay.classList.remove('hidden');
    };

    const close = () => {
      sidebar.classList.add('-translate-x-full');
      overlay.classList.add('hidden');
    };

    toggle.addEventListener('click', open);
    closeBtn.addEventListener('click', close);
    overlay.addEventListener('click', close);

    // Close on navigation (best-effort)
    sidebar.querySelectorAll('a').forEach(a => {
      a.addEventListener('click', () => close());
    });
  })();
</script>
